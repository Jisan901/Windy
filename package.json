{
  "name": "windy-ui-react",
  "version": "1.0.0",
  "description": "A flexible, Blender-inspired window management system for React.",
  "type": "module",
  "main": "./src/Windy.ts",
  "types": "./src/Windy.ts",
  "exports": {
    ".": {
      "types": "./src/Windy.ts",
      "default": "./src/Windy.ts"
    },
    "./ui": {
      "types": "./src/WindyUI.tsx",
      "default": "./src/WindyUI.tsx"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build -c vite.lib.config.ts && vite build",
    "build:lib": "vite build -c vite.lib.config.ts",
    "build:app": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "lucide-react": "^0.546.0"
  },
  "dependencies": {
    "lucide-react": "^0.546.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.183.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.5.4"
  }
}
